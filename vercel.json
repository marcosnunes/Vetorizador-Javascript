{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*\\.(js|css|ico|wasm|json))",
      "dest": "/$1"
    },
    {
      "src": "/vetoriza/pkg/(.*)",
      "dest": "/vetoriza/pkg/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
