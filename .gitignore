# .gitignore
node_modules/
.DS_Store
dist/
.vercel
.env
.env.*
!.env.example
*.token
*swa*token*
pdfspliter/.venv/
pdfspliter/PDFtoArcgis/testes/

# Documentação interna (manter apenas README.md público)
.github/copilot-instructions.md

.vercel
.env*.local

# Large binary/build artifacts — never commit to git
vetoriza/target/
pdfspliter/PDFtoArcgis/models/
pdfspliter/PDFtoArcgis/llama-cli/

# Python virtual environments (local only — never commit)
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.pyo

# PaddleOCR temp/cache artefacts
api/local-ocr/__pycache__/
api/local-ocr/*.pyc
api/local-ocr/paddle_ocr_tmp_*
